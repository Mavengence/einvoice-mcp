# KoSIT Validator URL (default: http://localhost:8081)
KOSIT_URL=http://localhost:8081

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Size limits (hard-coded defaults, shown here for reference)
# MAX_XML_SIZE=10485760        # 10 MB max XML input
# MAX_PDF_BASE64_SIZE=52428800 # ~50 MB max base64-encoded PDF
# MAX_PDF_DECODED_SIZE=41943040 # ~40 MB max decoded PDF binary
